# Copy to .env (gitignored) and fill in secrets.

# --- Local ---
# AI_RPG_MODEL_PROVIDER=ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen3:8b

# --- Cloud / agents (OpenAI-compatible) ---
# Preferred for Grok / xAI:
AI_RPG_MODEL_PROVIDER=openai
AI_RPG_API_PRESET=xai
AI_RPG_API_BASE_URL=https://api.x.ai/v1
AI_RPG_API_MODEL=grok-4.5
XAI_API_KEY=

# Or OpenAI:
# AI_RPG_API_PRESET=openai
# AI_RPG_API_BASE_URL=https://api.openai.com/v1
# AI_RPG_API_MODEL=gpt-4.1-mini
# OPENAI_API_KEY=

# Or any gateway (LiteLLM, OpenRouter, local proxy):
# AI_RPG_API_PRESET=custom
# AI_RPG_API_BASE_URL=http://127.0.0.1:4000/v1
# AI_RPG_API_MODEL=my-agent
# AI_RPG_API_KEY=

# Optional shared secret for external agent scripts hitting /api/agent/*
# AI_RPG_AGENT_TOKEN=change-me

# Story engine
# AI_RPG_NARRATION_PIPELINE=1
# AI_RPG_DRAFT_MODE=dsl

# Release default: debug OFF (no model-trace files, no debug_trace_path in API).
# AI_RPG_DEBUG=1
# AI_RPG_MODEL_TRACE_KEEP=50

# --- Local images (optional: Forge / A1111 or ComfyUI) ---
# AI_RPG_IMAGE_PROVIDER=off
# AI_RPG_IMAGE_PROVIDER=forge
# AI_RPG_FORGE_URL=http://127.0.0.1:7860
# AI_RPG_IMAGE_PROVIDER=comfyui
# AI_RPG_COMFY_URL=http://127.0.0.1:8188
# AI_RPG_COMFY_CHECKPOINT=v1-5-pruned-emaonly.safetensors
# AI_RPG_COMFY_WORKFLOW=txt2img_api.json
# AI_RPG_IMAGE_WIDTH=512
# AI_RPG_IMAGE_HEIGHT=512
# AI_RPG_IMAGE_STEPS=20
# AI_RPG_PORTRAIT_STYLE=pixel art portrait, 8-bit style, front view, bust
